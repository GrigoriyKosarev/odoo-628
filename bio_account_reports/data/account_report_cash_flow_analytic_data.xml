            <field name="expression_ids" eval="[(4, ref('account_report_cash_flow_analytic_line_cash_outflow_expression_budget'))]"/>
            <field name="expression_ids" eval="[(4, ref('account_report_cash_flow_analytic_line_cash_outflow_expression_remaining_balance'))]"/>
