        <record id="account_report_cash_flow_analytic_column_budget" model="account.report.column">
            <field name="name">Budget</field>
            <field name="expression_label">budget</field>
            <field name="figure_type">monetary</field>
            <field name="sortable" eval="False"/>
            <field name="blank_if_zero" eval="True"/>
        </record>
        <record id="account_report_cash_flow_analytic_column_remaining_balance" model="account.report.column">
            <field name="name">Remaining balance</field>
