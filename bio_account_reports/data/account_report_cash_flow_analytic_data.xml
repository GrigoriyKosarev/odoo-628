            <field name="subformula">remaining_balance</field>
            <field name="figure_type">monetary</field>
        </record>
        <record id="account_report_cash_flow_analytic_line_cash_outflow_expression_achievement" model="account.report.expression">
            <field name="report_line_id" ref="selferp_cashflow_analytic.account_report_cash_flow_analytic_line_cash_outflow"/>
            <field name="label">achievement</field>
            <field name="engine">custom</field>
